# =====================================================================
# CodeArts Pipeline MCP Server — environment variables
#
# This server reads its config from the SHARED .env in the repo root.
# Do NOT duplicate AK/SK here — they are shared across all MCP servers.
#
# Variables consumed by this server:
#   HUAWEICLOUD_ACCESS_KEY_ID   (required, shared)
#   HUAWEICLOUD_SECRET_ACCESS_KEY (required, shared)
#   CODEARTS_REGION             (required — NOT interchangeable with HUAWEICLOUD_REGION)
#   CODEARTS_DEFAULT_PROJECT_ID (recommended)
#   MCP_AUTH_MODE               (required — gateway | standalone | dev)
#   MCP_JWT_PUBLIC_KEY          (required if MCP_AUTH_MODE=standalone)
#   PIPELINE_MCP_LOG_LEVEL      (optional, default INFO)
#   PIPELINE_MCP_LOG_FILE       (optional)
#   PIPELINE_MCP_HTTP_TIMEOUT   (optional, default 30)
#   PIPELINE_MCP_NETWORK_RETRIES (optional, default 2)
# =====================================================================

CODEARTS_REGION=af-south-1
CODEARTS_DEFAULT_PROJECT_ID=your-codearts-project-id
# PIPELINE_MCP_LOG_LEVEL=INFO
# PIPELINE_MCP_LOG_FILE=/var/log/pipeline-mcp-server.log
# PIPELINE_MCP_HTTP_TIMEOUT=30
# PIPELINE_MCP_NETWORK_RETRIES=2
