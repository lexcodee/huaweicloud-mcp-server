# =====================================================================
# ECS MCP Server — environment variables
#
# This server reads its config from the SHARED .env in the repo root.
# Do NOT duplicate AK/SK or HUAWEICLOUD_PROJECT_ID here — they are
# shared across all MCP servers and managed in one place.
#
# Variables consumed by this server:
#   HUAWEICLOUD_ACCESS_KEY_ID   (required, shared)
#   HUAWEICLOUD_SECRET_ACCESS_KEY (required, shared)
#   HUAWEICLOUD_PROJECT_ID      (required, shared)
#   HUAWEICLOUD_REGION          (required)
#   MCP_AUTH_MODE               (required — gateway | standalone | dev)
#   MCP_JWT_PUBLIC_KEY          (required if MCP_AUTH_MODE=standalone)
#   ECS_MCP_LOG_LEVEL           (optional, default INFO)
#   ECS_MCP_LOG_FILE            (optional)
# =====================================================================

HUAWEICLOUD_REGION=af-south-1
# ECS_MCP_LOG_LEVEL=INFO
# ECS_MCP_LOG_FILE=/var/log/ecs-mcp-server.log
