# Minimal Nginx reverse-proxy in front of the MCP gateway.
#
# Key property: this file has exactly one `location /` block. Adding,
# removing, or renaming MCP servers behind the gateway does NOT require
# any change here — the gateway resolves all routing internally.

upstream mcp_gateway {
    server 127.0.0.1:8080;
    keepalive 32;
}

# Optional: a dedicated map for the SSE connection's long-lived nature.
# We disable response buffering for /sse to avoid Nginx accumulating bytes
# before flushing them to the client.
map $http_upgrade $is_event_stream {
    default 0;
    "" 0;
}

server {
    listen 443 ssl http2;
    server_name mcp.example.com;

    # TLS termination — replace with your certificate paths.
    ssl_certificate     /etc/letsencrypt/live/mcp.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mcp.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    # Generous timeouts for the SSE stream (client may stay connected for hours).
    proxy_read_timeout 1h;
    proxy_send_timeout 1h;

    location / {
        proxy_pass http://mcp_gateway;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection        "";

        # Streaming hygiene for SSE.
        proxy_buffering          off;
        proxy_cache              off;
        gzip                     off;
        chunked_transfer_encoding on;
    }
}

server {
    listen 80;
    server_name mcp.example.com;
    return 301 https://$host$request_uri;
}
