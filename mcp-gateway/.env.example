# =====================================================================
# MCP Gateway — environment variables
#
# This server reads its config from the SHARED .env in the repo root.
# Do NOT duplicate AK/SK or JWT keys here — they are shared across
# all MCP servers and managed in one place.
#
# Variables consumed by the gateway:
#   MCP_GATEWAY_HOST            (optional, default 0.0.0.0)
#   MCP_GATEWAY_PORT            (optional, default 8080)
#   MCP_GATEWAY_LOG_LEVEL       (optional, default info)
#   MCP_GATEWAY_MANIFEST        (optional, default ./manifest.yaml)
#   MCP_GATEWAY_ENABLED_SERVICES (optional, comma-separated service names)
#   MCP_JWT_PUBLIC_KEY          (required — PEM body, file:/path, or env:VAR)
#   MCP_JWT_ISSUER              (optional, default mcp-gateway)
#   MCP_JWT_AUDIENCE            (optional)
#   MCP_AUTH_MODE               (required — gateway | standalone | dev)
#
# Plus all variables required by the mounted MCP servers (see root .env.example).
# =====================================================================

MCP_GATEWAY_HOST=0.0.0.0
MCP_GATEWAY_PORT=8080
MCP_GATEWAY_LOG_LEVEL=info
# MCP_GATEWAY_MANIFEST=./manifest.yaml
# MCP_GATEWAY_ENABLED_SERVICES=ecs,pipeline,cts

MCP_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
MCP_JWT_ISSUER=mcp-gateway
# MCP_JWT_AUDIENCE=

MCP_AUTH_MODE=gateway
# MCP_DEV_SUBJECT=dev-local
# MCP_DEV_ROLES=admin
