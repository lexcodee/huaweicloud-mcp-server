# =====================================================================
# MCP Gateway + all MCP Servers — unified environment variables
#
# This is the SINGLE .env file for the entire workspace.
# Each sub-project only ships a .env.example that lists its own variables
# and points here for shared credentials.
#
# In production (systemd), load this via EnvironmentFile= in the unit.
# In development, python-dotenv loads it automatically from the repo root.
# =====================================================================

# --- Shared Huawei Cloud credentials (REQUIRED by all 3 MCP servers) ---
HUAWEICLOUD_ACCESS_KEY_ID=your-access-key-id
HUAWEICLOUD_SECRET_ACCESS_KEY=your-secret-access-key
HUAWEICLOUD_PROJECT_ID=your-project-id

# --- ECS MCP Server ---
HUAWEICLOUD_REGION=af-south-1
# ECS_MCP_LOG_LEVEL=INFO
# ECS_MCP_LOG_FILE=/var/log/ecs-mcp-server.log

# --- CodeArts Pipeline MCP Server ---
# NOTE: CODEARTS_REGION is NOT interchangeable with HUAWEICLOUD_REGION.
# CodeArts Pipeline has its own region catalogue. Set it explicitly.
CODEARTS_REGION=af-south-1
CODEARTS_DEFAULT_PROJECT_ID=your-codearts-project-id
# PIPELINE_MCP_LOG_LEVEL=INFO
# PIPELINE_MCP_LOG_FILE=/var/log/pipeline-mcp-server.log
# PIPELINE_MCP_HTTP_TIMEOUT=30
# PIPELINE_MCP_NETWORK_RETRIES=2

# --- CTS MCP Server ---
# CTS reuses HUAWEICLOUD_REGION and HUAWEICLOUD_PROJECT_ID from above.
# CTS_DEFAULT_TIMEZONE=Asia/Shanghai
# CTS_MCP_LOG_LEVEL=INFO
# CTS_MCP_LOG_FILE=/var/log/cts-mcp-server.log

# --- MCP Gateway ---
MCP_GATEWAY_HOST=0.0.0.0
MCP_GATEWAY_PORT=8080
MCP_GATEWAY_LOG_LEVEL=info
# MCP_GATEWAY_MANIFEST=manifest.yaml
# MCP_GATEWAY_ENABLED_SERVICES=ecs,pipeline,cts

# --- Gateway auth mode ---
# Controls how the gateway middleware authenticates incoming requests.
#   jwt       (default) — verify Bearer JWT with RS256 public key
#   dev       — skip JWT, synthesise admin identity for loopback callers only
#   disabled  — ⛔ DANGEROUS: skip all auth, every request allowed
MCP_GATEWAY_AUTH_MODE=jwt
# MCP_DEV_SUBJECT=dev-local
# MCP_DEV_ROLES=admin

# --- JWT public key (REQUIRED when MCP_GATEWAY_AUTH_MODE=jwt) ---
#
# This is the RS256 public key used to verify incoming JWTs.
# The SAME key is used by both:
#   1. Gateway middleware (reads via manifest.yaml → jwt.public_key)
#   2. Server StandaloneAuth (reads MCP_JWT_PUBLIC_KEY directly)
#
# Three ways to set it:
#
#   方式 1: 指向 PEM 文件（推荐生产环境）
#     MCP_JWT_PUBLIC_KEY=file:/etc/mcp-gateway/jwt-public.pem
#
#   方式 2: 指向另一个环境变量（适用于 systemd EnvironmentFile 不便写多行的场景）
#     MCP_JWT_PUBLIC_KEY=env:JWT_PUBKEY_PEM
#     JWT_PUBKEY_PEM=-----BEGIN PUBLIC KEY-----...
#
#   方式 3: 直接写 PEM 内容（仅限开发环境，.env 中换行用 \n 转义）
#     MCP_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBg...\n-----END PUBLIC KEY-----\n
#
# 推荐方式 1：先生成密钥对，再用 file: 引用
#   openssl genrsa -out jwt-private.pem 2048
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
#   然后设置 MCP_JWT_PUBLIC_KEY=file:/path/to/jwt-public.pem
#
MCP_JWT_PUBLIC_KEY=file:/etc/mcp-gateway/jwt-public.pem
MCP_JWT_ISSUER=mcp-gateway
# MCP_JWT_AUDIENCE=

# --- Per-server auth (auto-detect, no config needed) ---
# When running behind the gateway: identity is read from scope["mcp_identity"]
#   (injected by the gateway middleware after JWT verification).
# When running standalone (stdio / SSE without gateway): a dev identity is
#   synthesised automatically with a WARNING log. No MCP_AUTH_MODE needed.
